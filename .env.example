# Required keys
NVIDIA_API_KEY=
NGC_API_KEY=

# Runtime mode
# false: NVIDIA hosted endpoints (default)
# true: local NIM profile (--profile local-nim)
USE_LOCAL_NIM=false
USE_CPU_MILVUS=true

# Optional compose/env settings
DOCKER_VOLUME_DIRECTORY=./deploy/compose
PGADMIN_DEFAULT_EMAIL=pgadmin4@pgadmin.org
PGADMIN_DEFAULT_PASSWORD=admin
LOGLEVEL=INFO
UI_PORT=3001
API_GATEWAY_PORT=9000
AGENT_CHAIN_PORT=8081
ANALYTICS_PORT=8082
UNSTRUCTURED_RETRIEVER_PORT=8086
STRUCTURED_RETRIEVER_PORT=8087
POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_COMMANDER_PORT=9092
MINIO_PORT=9010
MINIO_CONSOLE_PORT=9011
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
