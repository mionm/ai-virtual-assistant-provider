# Required keys
NVIDIA_API_KEY=
NGC_API_KEY=

# Runtime mode
# false: NVIDIA hosted endpoints (default)
# true: local NIM profile (--profile local-nim)
USE_LOCAL_NIM=false
USE_CPU_MILVUS=true

# Optional compose/env settings
DOCKER_VOLUME_DIRECTORY=./deploy/compose
PGADMIN_DEFAULT_EMAIL=pgadmin4@pgadmin.org
PGADMIN_DEFAULT_PASSWORD=admin
LOGLEVEL=INFO
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=customer_data
POSTGRES_USER_READONLY=postgres_readonly
POSTGRES_PASSWORD_READONLY=readonly_password
CUSTOMER_DATA_DB=customer_data
UI_PORT=6020
API_GATEWAY_PORT=6001
AGENT_CHAIN_PORT=6002
ANALYTICS_PORT=6003
UNSTRUCTURED_RETRIEVER_PORT=6004
STRUCTURED_RETRIEVER_PORT=6005
POSTGRES_PORT=6006
REDIS_PORT=6007
REDIS_COMMANDER_PORT=6008
MINIO_PORT=6009
MINIO_CONSOLE_PORT=6010
MILVUS_PORT=6011
MILVUS_HEALTH_PORT=6012
